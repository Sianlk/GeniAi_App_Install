name: Auto Fix AI Workflow

on:
  workflow_dispatch:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  autofix:
    runs-on: ubuntu-latest
    steps:
    - name: Checkout repo
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.x'

    - name: Install flake8 and eslint
      run: |
        pip install flake8
        npm install -g eslint

    - name: Run auto-fix script
      run: python3 script/auto_fix.py
