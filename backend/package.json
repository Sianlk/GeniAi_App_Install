{
  "name": "unified-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "validate:secrets": "node ../scripts/validate_secrets.mjs --profile runtime --env-file ../.env",
    "validate:deploy-secrets": "node ../scripts/validate_secrets.mjs --profile deploy --env-file ../.env",
    "predev": "npm run validate:secrets",
    "dev": "tsx watch src/server.ts",
    "prestart": "npm run validate:secrets",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "tsx src/queues/worker.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.4",
    "@octokit/rest": "^21.0.2",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@prisma/client": "^5.22.0",
    "adminjs": "^7.8.12",
    "argon2": "^0.41.1",
    "bullmq": "^5.9.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.4",
    "ioredis": "^5.4.1",
    "langchain": "^1.3.2",
    "pino": "^9.3.2",
    "stripe": "^16.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.4"
  }
}
