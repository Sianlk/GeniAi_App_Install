# Unified Backend (Node/Fastify) environment template
# Copy to .env and fill with real secrets. Never commit .env.

NODE_ENV=production
PORT=8080

# Infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unified_ai
REDIS_URL=redis://localhost:6379

# JWT/Auth
JWT_ACCESS_SECRET=replace_with_min_16_char_secret
JWT_REFRESH_SECRET=replace_with_min_16_char_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
SUPER_ADMIN_EMAIL=hosturserver@gmail.com

# Branding
LOGO_URL=https://cdn.sianlk.com/logo.png

# Billing
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_COUNTRY=GB

# AI integration
OPENAI_API_KEY=sk-xxx

# GitHub automation
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=Sianlk
GITHUB_REPO=GeniAi_App_Install

# Security/scan
SNYK_TOKEN=snyk_xxx

# Deployment
DIGITALOCEAN_ACCESS_TOKEN=dop_v1_xxx
DIGITALOCEAN_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
