{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "echo",
            "type": "shell",
            "command": "echo Hello"
        }
    ]
}{
      "name": "OmniProfit Quantum Core",
        "build": {
            "dockerfile": "Dockerfile",
                "args": {
                      "QUANTUM_SDK": "11.5.0-entangled",
                            "AI_CORE": "phi-3-quantum-4k",
                                  "OMNI_LICENSE": "${localEnv:OMNI_LICENSE_KEY}"
                                      }
                                        },
                                          "features": {
                                              "ghcr.io/devcontainers/features/quantum-toolchain": {
                                                    "version": "6.9",
                                                          "entanglementPairs": 2048
                                                              },
                                                                  "ghcr.io/devcontainers-contrib/features/photonic-gpu": {
                                                                        "driverVersion": "550.54.14"
                                                                            }
                                                                              },
                                                                                "runArgs": ["--runtime=nvidia", "--privileged"],
                                                                                  "postCreateCommand": "bash .devcontainer/post-init.sh",
                                                                                    "customizations": {
                                                                                        "vscode": {
                                                                                              "extensions": [
                                                                                                      "quantumcode.vscode-quantum-syntax",
                                                                                                              "omniprofit.holographic-preview"
                                                                                                                    ]
                                                                                                                        }
                                                                                                                          }
                                                                                                                          }
                                                                                                                          
}